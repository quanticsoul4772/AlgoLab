{
  "name": "algolab-vscode",
  "displayName": "AlgoLab",
  "description": "Coloration syntaxique et snippets pour le pseudo-code AlgoLab",
  "version": "0.1.0",
  "publisher": "algolab",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "main": "./extension.js",
  "icon": "images/algolab-full.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/adandeigor/AlgoLab.git"
  },
  "contributes": {
    "commands": [
      {
        "command": "algolab.run",
        "title": "Exécuter AlgoLab",
        "icon": "$(play)"
      }
    ],
    "configuration": {
      "title": "AlgoLab",
      "properties": {
        "algolab.executablePath": {
          "type": "string",
          "default": "algolab",
          "description": "Chemin vers l'exécutable AlgoLab (commande ou chemin absolu)."
        }
      }
    },
    "menus": {
      "editor/title/run": [
        {
          "when": "resourceExtname == .algo",
          "command": "algolab.run",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "algolab",
        "aliases": [
          "AlgoLab",
          "algolab"
        ],
        "extensions": [
          ".algo"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/algolab-icon.png",
          "dark": "./images/algolab-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "algolab",
        "scopeName": "source.algolab",
        "path": "./syntaxes/algolab.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "algolab",
        "path": "./snippets/algolab.code-snippets"
      }
    ]
  }
}
